<Window x:Class="AllatokCsoportMunka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AllatokCsoportMunka"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="3*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <DataGrid Grid.Row="1" ItemsSource="{Binding Allatok}" Width="600" IsReadOnly="True" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Név" Width="*" Binding="{Binding Nev}"/>
                <DataGridTextColumn Header="Kontinens(ek)" Width="1.5*" Binding="{Binding Kontinens}"/>
                <DataGridTextColumn Header="Élettartam" Width="*" Binding="{Binding Elettartam}"/>
                <DataGridTextColumn Header="Táplálék" Width="*" Binding="{Binding Taplalek}"/>
                <DataGridTextColumn Header="Osztály" Width="*" Binding="{Binding Osztaly}"/>
            </DataGrid.Columns>
        </DataGrid>
        <Button Content="Button" HorizontalAlignment="Left" Margin="213,48,0,0" Grid.Row="2" VerticalAlignment="Top"/>

    </Grid>
</Window>
